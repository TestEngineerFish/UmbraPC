{
  "name": "umbra-pc",
  "version": "0.1.0",
  "description": "Umbra 私人 AI 助手 · PC 桌面客户端（Electron + Vite + TypeScript）",
  "private": true,
  "author": "Umbra",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:electron": "node scripts/build-electron.mjs",
    "watch:electron": "node scripts/build-electron.mjs --watch",
    "electron": "vite build && npm run build:electron && electron .",
    "electron:dev": "npm run build:electron && VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "prepackage": "vite build && npm run build:electron",
    "pack:mac": "npm run prepackage && electron-builder --mac --dir --config electron-builder.yml",
    "dist:mac": "npm run prepackage && electron-builder --mac --config electron-builder.yml",
    "dist:win": "npm run prepackage && electron-builder --win --config electron-builder.yml"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.2",
    "electron": "^31.0.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.21.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
